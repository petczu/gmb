APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=gmb_build
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Reviews provider: fake | zernio
REVIEWS_DRIVER=fake
ZERNIO_BASE_URL=https://zernio.com/api/v1
ZERNIO_WEBHOOK_SECRET=

# AI (review replies): fake | claude
AI_DRIVER=fake
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8
ZERNIO_API_KEY=

# Google OAuth (filament-socialite) — sign in / sign up with Google on the app panel
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/oauth/callback/google"

# LinkedIn OAuth login (optional — the button appears once configured).
# Create an app at linkedin.com/developers, product "Sign In with LinkedIn
# using OpenID Connect"; redirect: ${APP_URL}/oauth/callback/linkedin-openid
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Microsoft OAuth login (optional — the button appears once configured).
# Register an app in Azure Entra ID; redirect: ${APP_URL}/oauth/callback/microsoft
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common
# Google Places API (New) key — powers the competitor benchmark page.
# Empty = feature disabled.
GOOGLE_PLACES_API_KEY=

# AI credit top-ups (per-credit price)
STRIPE_PRICE_CREDIT=
CREDIT_PRICE=0.08
AI_REPORT_CREDITS=5
# Global monthly USD ceiling for ALL AI spend (alert-only: super-admins are
# emailed at 80% and 100%). Empty = no budget alerts.
AI_MONTHLY_BUDGET_USD=

STRIPE_PRICE_CREDIT_VOLUME=
CREDIT_VOLUME_THRESHOLD=500
CREDIT_VOLUME_DISCOUNT=10
CREDIT_MAX=5000

SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2
